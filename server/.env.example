# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Simply Analytics — Server Environment Variables                            │
# │                                                                             │
# │  Copy to server/.env and fill in your values, or run:  node setup.js        │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_MAX=1000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=8h
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=
SESSION_TIMEOUT_MINUTES=20

# ── Metadata Backend ─────────────────────────────────────────────────────────
# "postgres" (recommended) or "snowflake"
METADATA_BACKEND=postgres

# ── PostgreSQL (used when METADATA_BACKEND=postgres) ─────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=simply_analytics
POSTGRES_USER=simply
POSTGRES_PASSWORD=

# ── Snowflake Service Account ────────────────────────────────────────────────
# Auth types: password, keypair, pat
SF_SERVICE_AUTH_TYPE=keypair
SF_SERVICE_ACCOUNT=
SF_SERVICE_USER=
SF_SERVICE_PASSWORD=
SF_SERVICE_PRIVATE_KEY_PATH=./keys/rsa_key.p8
SF_SERVICE_PRIVATE_KEY_PASS=
SF_SERVICE_TOKEN=
SF_SERVICE_ROLE=SIMPLY_SVC_ROLE
SF_SERVICE_WAREHOUSE=SIMPLY_WH
SF_SERVICE_DATABASE=SIMPLY_ANALYTICS
SF_SERVICE_SCHEMA=APP

# Set to true when behind a corporate proxy with self-signed certificates
SNOWFLAKE_INSECURE_CONNECT=false

# ── Snowflake OAuth (optional — for end-user OAuth login) ────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_OAUTH_CLIENT_ID=
SNOWFLAKE_OAUTH_CLIENT_SECRET=
SNOWFLAKE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ── Redis Sessions ───────────────────────────────────────────────────────────
# Docker default: redis://redis:6379  |  Local default: redis://localhost:6379
REDIS_URL=redis://localhost:6379
# Set to true to use in-memory sessions instead of Redis (single-server only)
DISABLE_REDIS=true
REDIS_SESSION_PREFIX=simply:session:
SESSION_TTL_SECONDS=28800

# ── SSO / SAML 2.0 (optional) ───────────────────────────────────────────────
SSO_ENABLED=false
SAML_ENTRYPOINT=https://your-idp.example.com/sso/saml
SAML_ISSUER=simply-analytics
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:3001/api/saml/callback

# ── SCIM 2.0 Provisioning (optional) ────────────────────────────────────────
SCIM_ENABLED=false
SCIM_BEARER_TOKEN=

# ── WebAuthn / Passkeys (optional) ──────────────────────────────────────────
APP_NAME=Simply Analytics
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# ── Debug ────────────────────────────────────────────────────────────────────
VERBOSE_LOGS=false
SEMANTIC_DEBUG=false
