# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Simply Analytics — Docker Compose Variables                                │
# │                                                                             │
# │  Copy to .env at the repo root.  These are read by docker-compose.yml to   │
# │  configure the postgres service.  Run `node setup.js` to generate this     │
# │  file automatically.                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘

POSTGRES_DB=simply_analytics
POSTGRES_USER=simply
POSTGRES_PASSWORD=
