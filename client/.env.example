# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Simply Analytics — Client Build-Time Variables                             │
# │                                                                             │
# │  Optional.  Copy to client/.env if you need to override defaults.           │
# │  These are baked into the Vite build at compile time.                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Override the API base URL (default: /api, which uses the nginx reverse proxy)
VITE_API_URL=/api

# Enable verbose debug logging in the browser console
VITE_DEBUG=false
